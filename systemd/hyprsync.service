[Unit]
Description=HyprSync - Dotfile sync daemon
Documentation=https://github.com/r2unit/hyprsync
After=network-online.target
Wants=network-online.target

[Service]
Type=notify
ExecStart=%h/.local/bin/hyprsync daemon
ExecReload=/bin/kill -HUP $MAINPID
Restart=on-failure
RestartSec=5
WatchdogSec=60

# Security hardening
NoNewPrivileges=yes
ProtectHome=read-only
ReadWritePaths=%h/.local/share/hyprsync %h/.config/hypr

[Install]
WantedBy=default.target
